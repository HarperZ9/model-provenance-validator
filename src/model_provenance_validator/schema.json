{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model Reference Provenance Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_version",
    "subject",
    "source",
    "references",
    "validation"
  ],
  "properties": {
    "envelope_version": {
      "type": "string",
      "const": "1"
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "official-doc",
            "paper",
            "release-note",
            "local-fixture",
            "other"
          ]
        }
      }
    },
    "references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "locator",
          "retrieved_at"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "retrieved_at": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\d{4}-\\d{2}-\\d{2}"
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "verified",
            "partial",
            "unknown"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
